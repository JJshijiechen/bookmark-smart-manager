{
  "manifest_version": 3,
  "name": "Smart Bookmark Manager",
  "version": "1.0.7",
  "description": "A safe local bookmark manager with domain cleanup and smart category folders. No API required.",
  "permissions": [
    "bookmarks",
    "tabs",
    "activeTab",
    "storage"
  ],
  "action": {
    "default_title": "Smart Bookmark Manager",
    "default_popup": "popup.html"
  },
  "options_page": "dashboard.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}